        <div class="feat-icon fi-orange"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#ff6d00" stroke-width="1.8"/><path d="M12 7v5.5l3 1.8" stroke="#ff6d00" stroke-width="1.8" stroke-linecap="round"/></svg></div>
