<!-- HOW IT WORKS -->
<section class="hiw" id="how-it-works">
  <div class="section-inner">
    <span class="section-eyebrow reveal">How It Works</span>
    <h2 class="section-title reveal">Three steps to <span class="teal">better scanning</span></h2>
    <p class="section-desc reveal">No waiting for a supervisor. No scheduling review sessions. Upload and get a full AI report while the scan is still fresh.</p>
    <div class="steps">
      <div class="step reveal"><div class="step-num num-teal">01</div><h3>Upload your scan</h3><p>Submit any ultrasound acquisition directly through ScanHub — GUSI's secure central platform for scan management and review.</p></div>
      <div class="step reveal"><div class="step-num num-orange">02</div><h3>AI analyzes in minutes</h3><p>Instant Review evaluates image quality, scan completeness, probe technique, and anatomical visualization — automatically.</p></div>
      <div class="step reveal"><div class="step-num num-green">03</div><h3>Get your report</h3><p>Receive a structured report covering strengths, areas for improvement, and specific, actionable steps for your very next scan.</p></div>
    </div>
  </div>
</section>
