<!-- FORM -->
<section class="form-section" id="early-access">
  <div class="form-inner">
    <div class="form-left reveal">
      <div style="font-family:var(--f-body);font-size:11px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:14px;">Pre-Launch</div>
      <h2>Be first in line.<br><em>No limits. No wait.</em></h2>
      <p class="lead">Instant Review is in pre-launch. Join the waitlist and we'll reach out when access opens for your institution.</p>
      <div class="perks">
        <div class="perk"><div class="perk-check"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5l2.5 2.5 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Priority access before public launch</div>
        <div class="perk"><div class="perk-check"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5l2.5 2.5 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Free trial period for early registrants</div>
        <div class="perk"><div class="perk-check"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5l2.5 2.5 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Input into features before full launch</div>
        <div class="perk"><div class="perk-check"><svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M2 5.5l2.5 2.5 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>Direct onboarding support from GUSI</div>
      </div>
    </div>
    <div class="reveal">
      <div class="form-card">
        <div id="form-area">
          <h3 class="form-title">Request Early Access</h3>
          <p class="form-subtitle">Takes under 60 seconds — no commitment required.</p>
          <div class="form-row">
            <div class="form-group"><label for="fname">First name</label><input type="text" id="fname" placeholder="Elena" autocomplete="given-name"></div>
            <div class="form-group"><label for="lname">Last name</label><input type="text" id="lname" placeholder="Marchetti" autocomplete="family-name"></div>
          </div>
          <div class="form-group"><label for="email">Work email</label><input type="email" id="email" placeholder="you@institution.edu" autocomplete="email"></div>
          <div class="form-row">
            <div class="form-group"><label for="role">Your role</label><select id="role"><option value="" disabled selected>Select role</option><option>Physician / Clinician</option><option>Resident / Fellow</option><option>Medical Student</option><option>Sonographer</option><option>Educator / Faculty</option><option>QA / Program Director</option><option>Other</option></select></div>
            <div class="form-group"><label for="domain">Clinical focus</label><select id="domain"><option value="" disabled selected>Select focus</option><option>Emergency / Critical Care</option><option>Musculoskeletal</option><option>Vascular</option><option>Abdominal / General</option><option>Point-of-care (POCUS)</option><option>Multiple / General</option></select></div>
          </div>
          <div class="form-group"><label for="institution">Institution or organization</label><input type="text" id="institution" placeholder="e.g. UCSF Medical Center" autocomplete="organization"></div>
          <div class="form-group"><label for="notes">Anything to share? <span style="font-weight:400;text-transform:none;letter-spacing:0;opacity:0.55">(optional)</span></label><textarea id="notes" placeholder="e.g. We run a 40-resident POCUS curriculum and are exploring QA tools..."></textarea></div>
          <button class="form-submit" onclick="handleSubmit()">Request Early Access →</button>
          <p class="form-fine">By submitting you agree to receive updates about Instant Review from GUSI. No spam, ever. <a href="#">Privacy policy</a></p>
        </div>
        <div class="success-msg" id="success-msg">
          <div class="success-icon">✓</div>
          <h3>You're on the list!</h3>
          <p>We'll be in touch when early access opens. In the meantime, explore GUSI's courses and simulation cases on ScanHub.</p>
        </div>
      </div>
    </div>
  </div>
</section>
