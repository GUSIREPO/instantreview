        <div class="feat-icon fi-teal"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3C7.03 3 3 7.03 3 12s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9z" stroke="#00848e" stroke-width="1.8"/><path d="M8.5 12l2.5 2.5 5-5" stroke="#00848e" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
